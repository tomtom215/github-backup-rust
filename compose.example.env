# github-backup-rust — Docker Compose environment template.
#
# Copy this file to `.env` in the same directory as `docker-compose.yml`
# and fill in the values for the profiles you use. Docker Compose loads
# `.env` automatically.
#
#     cp compose.example.env .env
#     $EDITOR .env
#     docker compose run --rm backup octocat --all
#
# Never commit your `.env` file — it contains secrets. A matching
# `.gitignore` rule should already exclude it.

# ── Required for every profile ────────────────────────────────────────────
# GitHub personal access token with at minimum `repo` scope (private
# repos) or `public_repo` (public-only). Classic PATs and fine-grained
# tokens both work.
GITHUB_TOKEN=ghp_replace_me

# ── AWS S3 profile (`--profile s3`) ───────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA_replace_me
AWS_SECRET_ACCESS_KEY=replace_me
S3_BUCKET=my-github-backup-bucket
S3_REGION=us-east-1

# ── Backblaze B2 profile (`--profile b2`) ─────────────────────────────────
B2_KEY_ID=replace_me
B2_APP_KEY=replace_me
B2_BUCKET=my-b2-bucket
B2_REGION=us-west-004

# ── MinIO profile (`--profile minio`) ─────────────────────────────────────
# Defaults work out-of-the-box against the bundled MinIO side service.
# Override these if you point at an existing MinIO deployment.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=github-backup

# ── Codeberg / Forgejo mirror profile (`--profile codeberg`) ──────────────
# Personal access token on the mirror target (Codeberg, Forgejo, Gitea,
# GitLab) with repository write scope.
MIRROR_TOKEN=replace_me
MIRROR_URL=https://codeberg.org
MIRROR_OWNER=your-username-or-org
